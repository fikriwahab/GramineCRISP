libos.entrypoint = "/main"
loader.log_level = "error"

loader.env.LD_LIBRARY_PATH = "/lib"

fs.insecure__keys.default = "ffeeddccbbaa99887766554433221100"

fs.mounts = [
  { path = "/lib", uri = "file:{{ gramine.runtimedir() }}" },
  { path = "/main", uri = "file:main" },
  { type = "encrypted", path = "/crisp", uri = "file:pf_dir" },
]

sgx.crisp.enabled = true
sgx.crisp.mode = "checker"
sgx.crisp.vault_path = "/crisp/vault.dat"
sgx.crisp.mc_path = "/tmp/crisp_mc.dat"
sgx.crisp.tracked_pfs = ["/crisp/a.dat", "/crisp/b.dat"]
sgx.crisp.queue_timeout_ms = 5000
sgx.crisp.checker_api_port = 19999

sgx.debug = true
sgx.enclave_size = "256M"
sgx.max_threads = 16

sgx.trusted_files = [
  "file:main",
  "file:{{ gramine.runtimedir() }}/",
]
